# Force LF for source files (matches .editorconfig end_of_line = lf)
*.cs       text eol=lf
*.csproj   text eol=lf
*.slnx     text eol=lf
*.sln      text eol=lf
*.json     text eol=lf
*.xml      text eol=lf
*.config   text eol=lf
*.manifest text eol=lf
*.md       text eol=lf
*.editorconfig text eol=lf
*.gitignore text eol=lf
