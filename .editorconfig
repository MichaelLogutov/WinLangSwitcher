resharper_csharp_empty_block_style = multiline

# C# - Syntax Style
# https://www.jetbrains.com/help/resharper/EditorConfig_CSHARP_CSharpCodeStylePageImplSchema.html
resharper_csharp_for_built_in_types = use_var
