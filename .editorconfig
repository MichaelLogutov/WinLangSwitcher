# Razor CSharp - CodeStyle
# https://www.jetbrains.com/help/resharper/EditorConfig_Razor_CSharp_RazorCodeStylePageImplSchema.html
[*.cshtml]
resharper_html_linebreaks_around_razor_statements = true
resharper_html_blank_lines_around_razor_functions = 1
resharper_html_blank_lines_around_razor_helpers = 1
resharper_html_blank_lines_around_razor_sections = 1
resharper_razor_always_use_end_of_line_brace_style = true
resharper_razor_remove_blank_lines_near_braces = true
resharper_razor_remove_this_qualifier = true
resharper_razor_prefer_qualified_reference = true

# Razor Pages
[*.cshtml.cs]
# Disable async postfix for method names
dotnet_diagnostic.VSTHRD200.severity = none
dotnet_analyzer_diagnostic.VSTHRD200.severity = none

# Generated files
[*.{generated|min}.*]
generated_code = true

# Tests
[Tests/**/*.cs]
# Disable async postfix for method names
dotnet_diagnostic.VSTHRD200.severity = none
dotnet_analyzer_diagnostic.VSTHRD200.severity = none

# WebApi Controllers
[Web*/**/*Controller.cs]
dotnet_diagnostic.VSTHRD200.severity = none
dotnet_analyzer_diagnostic.VSTHRD200.severity = none
